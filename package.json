  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.18.0"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "vercel": "^44.2.0"
  }
}

{
  "name": "medibridge",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend/my-app"
  ],
  "engines": {
  "node": "20.x"
},
  "scripts": {
    "dev:web": "npm --workspace frontend/my-app run dev",

# ── Required (MongoDB Atlas + JWT) ────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
JWT_SECRET=use-a-long-random-string-at-least-32-characters

# ── Optional: Mongo tuning (serverless) ───────────────────────────────────────
# MONGODB_MAX_POOL_SIZE=5
# MONGODB_SERVER_SELECTION_MS=15000

# ── Optional: Windows / flaky SRV DNS (local dev); not used on Vercel ─────────
# MONGODB_DNS_SERVERS=1.1.1.1,8.8.8.8

# ── Optional: separate frontend deployment (comma-separated origins) ────────
# Use * ONLY for demos — prefer explicit origins.
# ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# Vercel: Project → Settings → Environment Variables → add Production + Preview.
# Same-repo deploy: omit VITE_API_URL (axios defaults to relative /api).
#
# Builds: npm run build writes frontend/my-app/dist then stages to ./dist for Vercel.
